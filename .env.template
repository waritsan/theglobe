# Azure AI Configuration Template
# Copy this file to .env and fill in your actual values
# Then run: source .env && ./scripts/set-secrets.sh

# Azure AI Foundry / OpenAI Service
export AZURE_AI_ENDPOINT="https://your-resource-name.openai.azure.com/"
export AZURE_AGENT_ID="your-agent-assistant-id"

# Azure Entra ID (formerly Azure AD) Application
export AZURE_CLIENT_ID="your-application-client-id"
export AZURE_CLIENT_SECRET="your-application-client-secret"
export AZURE_TENANT_ID="your-tenant-id"

# Instructions:
# 1. Get AZURE_AI_ENDPOINT from Azure AI Foundry -> Deployments
# 2. Get AZURE_AGENT_ID from Azure AI Foundry -> Assistants
# 3. Create an app registration in Azure Entra ID for authentication
# 4. Get AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, AZURE_TENANT_ID from the app registration